---
import Page from '@/layouts/Page.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';
import PageHeader from '@/components/PageHeader.astro';
import TimelineItem from '@/components/TimelineItem.astro';
import TreeCard from '@/components/TreeCard.astro';

const lang: Lang = 'en';
---

<Page title={t(lang, 'meta.title')} description={t(lang, 'meta.description')}>

  <!-- Page Header -->
  <PageHeader
    eyebrow={t(lang, 'story.eyebrow')}
    title={t(lang, 'story.title')}
    subtitle={t(lang, 'story.subtitle')}
  />

  <!-- Purpose & Foundations -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="t-label section-eyebrow">{t(lang, 'story.purpose.eyebrow')}</div>
      </div>
      <div class="purpose-grid">
        {[
          { titleKey: 'story.purpose.objective.title', textKey: 'story.purpose.objective' },
          { titleKey: 'story.purpose.mission.title', textKey: 'story.purpose.mission' },
          { titleKey: 'story.purpose.vision.title', textKey: 'story.purpose.vision' },
          { titleKey: 'story.purpose.goal.title', textKey: 'story.purpose.goal' },
        ].map(({ titleKey, textKey }) => (
          <div class="purpose-card">
            <h3 class="purpose-card__title">{t(lang, titleKey as any)}</h3>
            <p class="purpose-card__text">{t(lang, textKey as any)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="t-label section-eyebrow">{t(lang, 'story.timeline.eyebrow')}</div>
        <h2 class="t-display t-display--md">{t(lang, 'story.timeline.title')}</h2>
      </div>
      <div class="timeline">
        <TimelineItem
          year="2006"
          title={t(lang, 'story.2006.title')}
          text={t(lang, 'story.2006.text')}
        />
        <TimelineItem
          year="2008"
          title={t(lang, 'story.2008.title')}
          text={t(lang, 'story.2008.text')}
        />
        <TimelineItem
          year="2012"
          title={t(lang, 'story.2012.title')}
          text={t(lang, 'story.2012.text')}
        />
        <TimelineItem
          year="Today"
          title={t(lang, 'story.today.title')}
          text={t(lang, 'story.today.text')}
        />
      </div>
    </div>
  </section>

  <!-- Three Pillars + Tree of Life -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="t-label section-eyebrow">{t(lang, 'story.pillars.eyebrow')}</div>
        <h2 class="t-display t-display--md">{t(lang, 'story.pillars.title')}</h2>
        <p class="section-subtitle">{t(lang, 'story.tree.subtitle')}</p>
      </div>

      <!-- Three Pillar Cards -->
      <div class="pillars-grid">
        {[
          { key: 'story.pillar1', icon: '\u{1F393}' },
          { key: 'story.pillar2', icon: '\u{1F91D}' },
          { key: 'story.pillar3', icon: '\u{1F331}' },
        ].map(({ key, icon }) => (
          <div class="pillar-card">
            <div class="pillar-card__icon">{icon}</div>
            <h3 class="pillar-card__title">{t(lang, `${key}.title` as any)}</h3>
            <p class="pillar-card__text">{t(lang, `${key}.text` as any)}</p>
          </div>
        ))}
      </div>

      <!-- Support Areas -->
      <h3 class="support-areas-title">Support Areas</h3>
      <div class="tree-grid">
        <TreeCard icon="\u{1F4BB}" title={t(lang, 'story.tree.technology')} text={t(lang, 'story.tree.technologyText')} />
        <TreeCard icon="\u{1F4B0}" title={t(lang, 'story.tree.economic')} text={t(lang, 'story.tree.economicText')} />
        <TreeCard icon="\u{1F3A8}" title={t(lang, 'story.tree.artistic')} text={t(lang, 'story.tree.artisticText')} />
        <TreeCard icon="\u{1F499}" title={t(lang, 'story.tree.emotional')} text={t(lang, 'story.tree.emotionalText')} />
        <TreeCard icon="\u{1F3CA}" title={t(lang, 'story.tree.health')} text={t(lang, 'story.tree.healthText')} />
        <TreeCard icon="\u{1F3B6}" title={t(lang, 'story.tree.cultural')} text={t(lang, 'story.tree.culturalText')} />
        <TreeCard icon="\u{1F465}" title={t(lang, 'story.tree.psychological')} text={t(lang, 'story.tree.psychologicalText')} />
        <TreeCard icon="\u{1F389}" title={t(lang, 'story.tree.social')} text={t(lang, 'story.tree.socialText')} />
      </div>
    </div>
  </section>

  <!-- Logo Meaning -->
  <section class="section">
    <div class="container">
      <div class="logo-meaning">
        <div class="logo-meaning__content">
          <div class="t-label logo-meaning__eyebrow">{t(lang, 'story.logo.eyebrow')}</div>
          <h2 class="t-display t-display--md">{t(lang, 'story.logo.title')}</h2>
          <p class="logo-meaning__text">{t(lang, 'story.logo.text')}</p>
        </div>
        <div class="logo-meaning__visual">
          <img
            src="https://buildingbajasfuture.org/wp-content/uploads/2023/01/mark2.png"
            alt="BBF logo mark — a hand referencing prehistoric Baja California cave paintings"
            class="logo-meaning__img"
            width="400"
            height="400"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="t-label section-eyebrow">{t(lang, 'story.board.eyebrow')}</div>
        <h2 class="t-display t-display--sm">{t(lang, 'story.board.title')}</h2>
      </div>
      <div class="team-grid">
        {[
          { nameKey: 'story.board.president.name', roleKey: 'story.board.president.role' },
          { nameKey: 'story.board.secretary.name', roleKey: 'story.board.secretary.role' },
          { nameKey: 'story.board.treasurer.name', roleKey: 'story.board.treasurer.role' },
        ].map(({ nameKey, roleKey }) => (
          <div class="team-card">
            <h3 class="team-card__name">{t(lang, nameKey as any)}</h3>
            <p class="team-card__role">{t(lang, roleKey as any)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Staff -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="t-label section-eyebrow">{t(lang, 'story.staff.eyebrow')}</div>
      </div>
      <div class="team-grid team-grid--4">
        {[
          { nameKey: 'story.staff.mirna.name', roleKey: 'story.staff.mirna.role' },
          { nameKey: 'story.staff.alicia.name', roleKey: 'story.staff.alicia.role' },
          { nameKey: 'story.staff.amando.name', roleKey: 'story.staff.amando.role' },
          { nameKey: 'story.staff.lucy.name', roleKey: 'story.staff.lucy.role' },
        ].map(({ nameKey, roleKey }) => (
          <div class="team-card">
            <h3 class="team-card__name">{t(lang, nameKey as any)}</h3>
            <p class="team-card__role">{t(lang, roleKey as any)}</p>
          </div>
        ))}
      </div>
      <p class="reports-note">{t(lang, 'story.reports.intro' as any)}</p>
    </div>
  </section>

</Page>

<style>
  /* ═══════════════════════════════════════════════
     SECTION HEADER
     ═══════════════════════════════════════════════ */

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-eyebrow {
    color: var(--red);
    margin-bottom: var(--space-md);
  }

  .section-subtitle {
    color: var(--text-muted);
    max-width: 560px;
    margin: var(--space-md) auto 0;
    line-height: 1.75;
  }

  /* ═══════════════════════════════════════════════
     PURPOSE & FOUNDATIONS
     ═══════════════════════════════════════════════ */

  .purpose-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .purpose-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .purpose-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .purpose-card__text {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* ═══════════════════════════════════════════════
     TIMELINE
     ═══════════════════════════════════════════════ */

  .timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding-left: 60px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  /* ═══════════════════════════════════════════════
     THREE PILLARS
     ═══════════════════════════════════════════════ */

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .pillar-card {
    background: var(--bg-card);
    border: 2px solid var(--red);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .pillar-card__icon {
    font-size: 2rem;
    margin-bottom: var(--space-md);
  }

  .pillar-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .pillar-card__text {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .support-areas-title {
    text-align: center;
    margin: var(--space-xl) 0 var(--space-lg);
    color: var(--text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ═══════════════════════════════════════════════
     TREE OF LIFE GRID
     ═══════════════════════════════════════════════ */

  .tree-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  /* ═══════════════════════════════════════════════
     LOGO MEANING
     ═══════════════════════════════════════════════ */

  .logo-meaning {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .logo-meaning__eyebrow {
    color: var(--red);
    margin-bottom: var(--space-md);
  }

  .logo-meaning__content h2 {
    margin-bottom: var(--space-lg);
  }

  .logo-meaning__text {
    color: var(--text-muted);
    line-height: 1.8;
  }

  .logo-meaning__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .logo-meaning__img {
    max-width: 280px;
    width: 100%;
    opacity: 0.8;
  }

  /* ═══════════════════════════════════════════════
     BOARD & STAFF
     ═══════════════════════════════════════════════ */

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 800px;
    margin: 0 auto;
  }

  .team-grid--4 {
    grid-template-columns: repeat(4, 1fr);
    max-width: 900px;
  }

  .team-card {
    text-align: center;
    padding: var(--space-lg);
  }

  .team-card__name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .team-card__role {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .reports-note {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: var(--space-xl);
    font-style: italic;
  }

  /* ═══════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════ */

  @media (max-width: 1024px) {
    .tree-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }

    .tree-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .logo-meaning {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .logo-meaning__visual {
      order: -1;
    }

    .team-grid,
    .team-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .purpose-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .tree-grid {
      grid-template-columns: 1fr;
    }

    .team-grid,
    .team-grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>
