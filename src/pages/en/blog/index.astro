---
import { getCollection } from 'astro:content';
import Page from '@/layouts/Page.astro';
import PageHeader from '@/components/PageHeader.astro';
import BlogCard from '@/components/BlogCard.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

const lang: Lang = 'en';
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Page title={t(lang, 'blog.title') + ' — ' + t(lang, 'meta.title')} description={t(lang, 'blog.subtitle')}>

  <PageHeader
    eyebrow={t(lang, 'blog.eyebrow')}
    title={t(lang, 'blog.title')}
    subtitle={t(lang, 'blog.subtitle')}
  />

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            date={post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            excerpt={post.data.excerpt}
            image={post.data.image}
            href={`/en/blog/${post.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>

</Page>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  @media (max-width: 480px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
