---
import { getCollection } from 'astro:content';
import Page from '@/layouts/Page.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const lang: Lang = 'en';
const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Page title={post.data.title + ' — BBF'} description={post.data.excerpt}>

  <section class="section section--post-header">
    <div class="container container--narrow">
      <a href="/en/blog/" class="back-link">← {t(lang, 'blog.back')}</a>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span class="post-date">{formattedDate}</span>
        <span class="post-sep">·</span>
        <span class="post-author">{post.data.author}</span>
      </div>
    </div>
  </section>

  {post.data.image && (
    <section class="section section--post-image">
      <div class="container container--narrow">
        <img src={post.data.image} alt="" class="post-hero-img" loading="eager" />
      </div>
    </section>
  )}

  <section class="section section--post-body">
    <div class="container container--narrow">
      <div class="prose">
        <Content />
      </div>
    </div>
  </section>

</Page>

<style>
  .container--narrow {
    max-width: 720px;
  }

  /* ═══════════════════════════════════════════════
     POST HEADER
     ═══════════════════════════════════════════════ */

  .section--post-header {
    padding-bottom: var(--space-lg);
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--red);
    text-decoration: none;
    margin-bottom: var(--space-lg);
    transition: opacity 0.2s var(--ease-out);
  }

  .back-link:hover {
    opacity: 0.75;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .post-sep {
    opacity: 0.4;
  }

  /* ═══════════════════════════════════════════════
     HERO IMAGE
     ═══════════════════════════════════════════════ */

  .section--post-image {
    padding-top: 0;
    padding-bottom: var(--space-xl);
  }

  .post-hero-img {
    width: 100%;
    aspect-ratio: 16/7;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  /* ═══════════════════════════════════════════════
     PROSE
     ═══════════════════════════════════════════════ */

  .section--post-body {
    padding-top: 0;
  }

  .prose {
    color: var(--text);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--text);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--text);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--text);
  }

  .prose :global(a) {
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--red);
    padding-left: var(--space-lg);
    margin-left: 0;
    margin-right: 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-2xl) 0;
  }

  .prose :global(em) {
    color: var(--text-muted);
  }
</style>
