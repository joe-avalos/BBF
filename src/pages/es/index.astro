---
import Page from '@/layouts/Page.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';
import StatCounter from '@/components/StatCounter.astro';
import BcsCallout from '@/components/BcsCallout.astro';

const lang: Lang = 'es';
---

<Page title={t(lang, 'meta.title')} description={t(lang, 'meta.description')}>

  {/* Compact intro — no full-bleed hero */}
  <section class="intro">
    <div class="container">
      <h1 class="intro__title">{t(lang, 'home.es.intro')}</h1>
      <p class="intro__text">{t(lang, 'home.es.whatIsBbf')}</p>
      <BcsCallout variant="prominent" />
    </div>
  </section>

  {/* Impact stats — same animated counters as EN */}
  <section class="section stats-section">
    <div class="container">
      <div class="stats-grid">
        <StatCounter target={650} label={t(lang, 'stats.scholars')} suffix="+" />
        <StatCounter target={20} label={t(lang, 'stats.years')} />
        <StatCounter target={200} label={t(lang, 'stats.graduates')} />
      </div>
    </div>
  </section>

  {/* Scholarship benefits grid */}
  <section class="section section--alt">
    <div class="container">
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">🎓</div>
          <p class="benefit-label">{t(lang, 'home.es.benefits.tuition')}</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">📚</div>
          <p class="benefit-label">{t(lang, 'home.es.benefits.books')}</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">🤝</div>
          <p class="benefit-label">{t(lang, 'home.es.benefits.mentorship')}</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">💪</div>
          <p class="benefit-label">{t(lang, 'home.es.benefits.support')}</p>
        </div>
      </div>
    </div>
  </section>

  {/* How to apply steps */}
  <section class="section">
    <div class="container">
      <h2 class="steps__title">{t(lang, 'home.es.steps.title')}</h2>
      <div class="steps-grid">
        <div class="step">
          <span class="step__number">1</span>
          <p class="step__text">{t(lang, 'home.es.steps.step1')}</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <p class="step__text">{t(lang, 'home.es.steps.step2')}</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <p class="step__text">{t(lang, 'home.es.steps.step3')}</p>
        </div>
      </div>
    </div>
  </section>

  {/* Apply CTA */}
  <section class="apply-cta">
    <div class="container">
      <p class="apply-cta__text">{t(lang, 'home.es.applyCtaText')}</p>
      <a href="/es/how-to-apply/" class="btn btn--primary">{t(lang, 'nav.howToApply')}</a>
    </div>
  </section>

  <script src="../../js/stat-counter.ts"></script>
</Page>

<style>
  /* ═══════════════════════════════════════════════
     INTRO (replaces hero for ES)
     ═══════════════════════════════════════════════ */

  .intro {
    padding: var(--space-3xl, 5rem) 0 var(--space-xl, 2rem);
  }

  .intro__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.3;
    margin-bottom: var(--space-md, 1rem);
  }

  .intro__text {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: var(--space-md, 1rem);
  }

  /* ═══════════════════════════════════════════════
     STATS
     ═══════════════════════════════════════════════ */

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg, 2rem);
    text-align: center;
    padding: var(--space-xl, 2rem) 0;
  }

  /* ═══════════════════════════════════════════════
     BENEFITS
     ═══════════════════════════════════════════════ */

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-md, 1rem);
  }

  .benefit-card {
    padding: var(--space-lg, 1.5rem);
    background: var(--bg-card, #ffffff);
    border-radius: var(--radius, 4px);
    border: 1px solid var(--border);
    text-align: center;
  }

  .benefit-icon {
    font-size: 2rem;
    margin-bottom: var(--space-sm, 0.5rem);
  }

  .benefit-label {
    font-weight: 500;
    color: var(--text);
  }

  /* ═══════════════════════════════════════════════
     STEPS
     ═══════════════════════════════════════════════ */

  .steps__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    text-align: center;
    margin-bottom: var(--space-xl, 2rem);
  }

  .steps-grid {
    display: flex;
    gap: var(--space-xl, 2rem);
    justify-content: center;
  }

  .step {
    flex: 1;
    max-width: 240px;
    text-align: center;
  }

  .step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--red);
    color: white;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: var(--space-md, 1rem);
  }

  .step__text {
    color: var(--text);
    font-weight: 500;
  }

  /* ═══════════════════════════════════════════════
     APPLY CTA
     ═══════════════════════════════════════════════ */

  .apply-cta {
    text-align: center;
    padding: var(--space-xl, 2rem) 0 var(--space-3xl, 5rem);
    background: var(--bg-alt);
  }

  .apply-cta__text {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-bottom: var(--space-lg, 1.5rem);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ═══════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════ */

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .steps-grid {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
