---
interface Props {
  image: string;
  tag: string;
  title: string;
  text: string;
  link: string;
  linkText: string;
}

const { image, tag, title, text, link, linkText } = Astro.props;
---

<div class="program-card">
  <img src={image} alt="" class="program-card__img" loading="lazy" />
  <div class="program-card__body">
    <div class="program-card__tag t-label">{tag}</div>
    <h3 class="program-card__title">{title}</h3>
    <p class="program-card__text">{text}</p>
    <a href={link} class="btn btn--ghost">{linkText} &rarr;</a>
  </div>
</div>

<style>
  .program-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.4s var(--ease-out);
    position: relative;
  }

  .program-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    border-color: transparent;
  }

  :global([data-theme="dark"]) .program-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .program-card__img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .program-card__body {
    padding: var(--space-lg);
  }

  .program-card__tag {
    color: var(--red);
    margin-bottom: var(--space-sm);
  }

  .program-card__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .program-card__text {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  @media (prefers-reduced-motion: reduce) {
    .program-card {
      transition: none;
    }
    .program-card:hover {
      transform: none;
    }
  }
</style>
