---
interface Props {
  number: string;
  label: string;
  subLabel?: string;
}

const { number, label, subLabel } = Astro.props;
---

<div class="stat">
  <div class="stat__number">{number}</div>
  <div class="stat__label">{label}</div>
  {subLabel && <div class="stat__sublabel">{subLabel}</div>}
</div>

<style>
  .stat {
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    position: relative;
  }

  .stat__number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 600;
    color: var(--red);
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .stat__label {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .stat__sublabel {
    color: var(--text-light);
    font-size: 0.75rem;
    margin-top: 4px;
  }
</style>
