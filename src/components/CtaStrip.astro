---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  buttonText: string;
  buttonHref: string;
  trustText?: string;
}

const { eyebrow, title, text, buttonText, buttonHref, trustText } = Astro.props;
---

<section class="cta-strip">
  <div class="cta-strip__pattern"></div>
  <div class="container cta-strip__inner">
    <div class="cta-strip__content">
      <div class="cta-strip__eyebrow t-label">{eyebrow}</div>
      <h2 class="cta-strip__title">{title}</h2>
      <p class="cta-strip__text">{text}</p>
    </div>
    <div class="cta-strip__actions">
      <a href={buttonHref} target="_blank" rel="noopener" class="btn btn--donate">{buttonText}</a>
      {trustText && <span class="cta-strip__trust">{trustText}</span>}
    </div>
  </div>
</section>

<style>
  .cta-strip {
    background: var(--charcoal);
    color: var(--sand);
    padding: var(--space-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .cta-strip {
    background: #0f0d0c;
  }

  .cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    position: relative;
    z-index: 1;
  }

  .cta-strip__content {
    max-width: 600px;
  }

  .cta-strip__eyebrow {
    color: var(--gold);
    margin-bottom: var(--space-md);
  }

  .cta-strip__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .cta-strip__text {
    color: #c4bdb8;
    line-height: 1.7;
  }

  .cta-strip__actions {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .cta-strip__trust {
    font-size: 0.7rem;
    color: #a09893;
    letter-spacing: 0.08em;
  }

  .cta-strip__pattern {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 40%;
    opacity: 0.03;
    background: radial-gradient(circle at 70% 50%, var(--red) 0%, transparent 70%);
  }

  @media (max-width: 768px) {
    .cta-strip__inner {
      flex-direction: column;
      text-align: center;
    }

    .cta-strip__actions {
      width: 100%;
    }
  }
</style>
