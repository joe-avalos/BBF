---
import { getLang, t } from '@/i18n/utils';
import Logo from './Logo.astro';
import { allPages } from '../i18n/nav';

const lang = getLang(Astro.url);
const otherLang = lang === 'en' ? 'es' : 'en';
const currentLangPages = allPages[lang];
const otherLangPages = allPages[otherLang];

// TODO: Revisit with client — Jacinto questioned whether to publish the dual-entity
// disclaimer due to SAT concerns. Set to false to hide it.
const showDisclaimer = true;
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner">
    <div class="footer__grid">

      <!-- Column 1: Brand -->
      <div class="footer__col footer__col--brand">
        <a href={`/${lang}/`} class="footer__logo-link" aria-label="Building Baja's Future — Home">
          <Logo width={131} height={50} class="footer__logo" />
        </a>
        <p class="footer__entity-name">{t(lang, 'footer.entityName')}</p>
        <p class="footer__legal-note">{t(lang, 'footer.legal')}</p>
      </div>

      <!-- Column 2: Current language pages -->
      <div class="footer__col">
        <h3 class="footer__heading">{lang === 'en' ? 'Pages' : 'Páginas'}</h3>
        <ul class="footer__links">
          {currentLangPages.map(page => (
            <li><a href={page.href} class="footer__link">{t(lang, page.key as any)}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Other language pages -->
      <div class="footer__col">
        <h3 class="footer__heading">{lang === 'en' ? 'En Español' : 'In English'}</h3>
        <ul class="footer__links">
          {otherLangPages.map(page => (
            <li><a href={page.href} class="footer__link">{t(otherLang, page.key as any)}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div class="footer__col">
        <h3 class="footer__heading">{t(lang, 'footer.contact')}</h3>
        <address class="footer__address">
          {t(lang, 'footer.address.line1')}<br />
          {t(lang, 'footer.address.line2')}
        </address>
        <div class="footer__contact-links">
          <a href={`mailto:${t(lang, 'footer.email')}`} class="footer__link">{t(lang, 'footer.email')}</a>
          <a href={`tel:${t(lang, 'footer.phone').replace(/\s/g, '')}`} class="footer__link">{t(lang, 'footer.phone')}</a>
        </div>
      </div>

    </div>

    <div class="footer__bottom">
      <p class="footer__copy">{t(lang, 'footer.copy')}</p>
      {showDisclaimer && <p class="footer__disclaimer">{t(lang, 'footer.disclaimer')}</p>}
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--footer-bg);
    color: var(--footer-text);
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) 0;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  /* Brand column */
  .footer__col--brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer__logo-link {
    display: inline-block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .footer__logo {
    display: block;
    height: 50px;
    width: auto;
    color: #fff;
    opacity: 0.9;
  }

  .footer__entity-name {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.6;
    color: var(--footer-text);
    opacity: 0.85;
    margin: 0;
    max-width: 28ch;
  }

  .footer__legal-note {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--footer-text);
    opacity: 0.55;
    margin: 0;
    max-width: 32ch;
  }

  /* Nav columns */
  .footer__heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--footer-text);
    opacity: 0.5;
    margin: 0 0 var(--space-md);
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--footer-text);
    text-decoration: none;
    opacity: 0.8;
    transition: color 0.2s var(--ease-out), opacity 0.2s var(--ease-out);
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: #ffffff;
    opacity: 1;
  }

  /* Contact links */
  .footer__contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  /* Address */
  .footer__address {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-style: normal;
    line-height: 1.6;
    color: var(--footer-text);
    opacity: 0.8;
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
  }

  .footer__copy,
  .footer__disclaimer {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--footer-text);
    opacity: 0.5;
    margin: 0;
  }

  /* Tablet: 2-column grid */
  @media (max-width: 960px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }

    .footer__col--brand {
      grid-column: 1 / -1;
    }

    .footer__entity-name,
    .footer__legal-note {
      max-width: 50ch;
    }
  }

  /* Mobile: single column */
  @media (max-width: 560px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer__col--brand {
      grid-column: auto;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .footer__link {
      transition: none;
    }
  }
</style>
