---
interface Props {
  name: string;
  photo: string;
  university: string;
  degree: string;
  status: string;
}

const { name, photo, university, degree, status } = Astro.props;
---

<div class="scholar-card" data-university={university} data-degree={degree} data-status={status}>
  <div class:list={['scholar-photo', { 'scholar-photo--default': !photo }]}>
    <img src={photo || '/scholars/default-thumbnail.svg'} alt={name} width="300" height="300" loading="lazy" />
  </div>
  <div class="scholar-info">
    <h3 class="scholar-name">{name}</h3>
    <p class="scholar-university">{university}</p>
    <p class="scholar-degree">{degree}</p>
    <span class:list={['scholar-status', `scholar-status--${status.toLowerCase()}`]}>{status}</span>
  </div>
</div>

<style>
  .scholar-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: all 0.3s var(--ease-out);
  }

  .scholar-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* ═══════════════════════════════════════════════
     PHOTO
     ═══════════════════════════════════════════════ */

  .scholar-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .scholar-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scholar-photo--default img {
    object-fit: contain;
    padding: var(--space-lg);
    opacity: 0.4;
  }

  /* ═══════════════════════════════════════════════
     INFO
     ═══════════════════════════════════════════════ */

  .scholar-info {
    padding: var(--space-md);
  }

  .scholar-name {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .scholar-university {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 2px;
  }

  .scholar-degree {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0 0 var(--space-sm);
  }

  /* ═══════════════════════════════════════════════
     STATUS BADGE
     ═══════════════════════════════════════════════ */

  .scholar-status {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .scholar-status--active {
    background: color-mix(in srgb, var(--red) 12%, transparent);
    color: var(--red);
  }

  .scholar-status--graduated {
    background: color-mix(in srgb, var(--text-muted) 12%, transparent);
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════════════ */

  @media (prefers-reduced-motion: reduce) {
    .scholar-card {
      transition: none;
    }
    .scholar-card:hover {
      transform: none;
    }
  }
</style>
