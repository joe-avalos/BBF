---
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  size?: 'sm' | 'lg';
  lang: Lang;
  label?: string;
}

const { size = 'lg', lang, label } = Astro.props;
const btnClass = size === 'sm' ? 'btn btn--donate-sm' : 'btn btn--donate';
const text = label ?? t(lang, 'nav.donate');

const PAYPAL_URL =
  'https://www.paypal.com/donate?token=m4ld99YqY75fhl96dRcSwlq_eay6RuFri7OTfucgIWOJZIlrQ7FZaFYVka9sdwSyguC9cqmvuEZrv_uS';
---

<button type="button" data-donate class={btnClass}>
  {text}
</button>
<noscript>
  <a
    href={PAYPAL_URL}
    target="_blank"
    rel="noopener noreferrer"
    class={btnClass}
  >
    {text}
  </a>
</noscript>

<script>
  import { initDonateButtons } from '@/js/paypal';
  initDonateButtons();
</script>
